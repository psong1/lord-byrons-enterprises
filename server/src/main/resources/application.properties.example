# Copy this file to application.properties (same folder) and replace every placeholder.
# application.properties is gitignored — never commit real secrets.

# ================================
# SERVER CONFIGURATION
# ================================
server.port=8080
spring.application.name=Lord Byrons Enterprises Limited

# ================================
# DATABASE CONFIGURATION (MySQL)
# ================================
spring.datasource.url=jdbc:mysql://localhost:3306/your_database_name?allowPublicKeyRetrieval=true&useSSL=false
spring.datasource.username=YOUR_USERNAME
spring.datasource.password=YOUR_PASSWORD
spring.sql.init.mode=never
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# Connection Pool Configuration (HikariCP - default in Spring Boot)
spring.datasource.hikari.maximum-pool-size=10
spring.datasource.hikari.minimum-idle=5
spring.datasource.hikari.connection-timeout=30000
spring.datasource.hikari.idle-timeout=600000
spring.datasource.hikari.max-lifetime=1800000

# ================================
# JPA / HIBERNATE CONFIGURATION
# ================================
# Dev-friendly: auto-applies schema changes. Production often uses validate + Flyway/Liquibase instead.
spring.jpa.hibernate.ddl-auto=update
# Dev-only noise; set show-sql=false and drop SQL DEBUG logging in production.
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

# ================================
# OPTIONAL (LOGGING, TIMEZONE, ETC.)
# ================================
spring.jackson.time-zone=UTC
logging.level.org.hibernate.SQL=DEBUG

# ================================
# JWT CONFIGURATION
# ================================
# Use a long random string (e.g. 256+ bits). Not the same value as your Stripe secret key.
application.security.jwt.secret-key=REPLACE_WITH_LONG_RANDOM_SECRET_FOR_JWT_SIGNING

# ================================
# STRIPE CONFIGURATION
# ================================
# From Stripe Dashboard (test mode): sk_test_...
stripe.secret.key=REPLACE_WITH_STRIPE_SECRET_KEY_sk_test_or_sk_live
